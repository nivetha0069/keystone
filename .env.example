# Base URL that already exposes /cis, /timeline, /relationships, and /health.
CMDB_API_BASE_URL=https://your-servicenow-api.example.com

# Choose bearer token OR basic authentication. These remain server-side.
CMDB_API_TOKEN=
CMDB_API_USERNAME=
CMDB_API_PASSWORD=
CMDB_AGENT_BATCH_APPROVAL_ENABLED=false
CMDB_MARA_AUTONOMOUS_COMMIT_ENABLED=false
# Exact uppercase parent SHA-256 authorized for one bounded approval packet.
# Leave unset during planning, preparation, simulation, and local verification.
CMDB_AGENT_APPROVAL_PACKET_HASH=

# Optional. If omitted, remediation proposals use CMDB_API_BASE_URL/remediate.
CMDB_REMEDIATE_URL=
CMDB_IMPORT_URL=

# Optional. If omitted, IRE actions use CMDB_API_BASE_URL/ire/{simulate,approve,execute,verify}.
CMDB_IRE_BASE_URL=
CMDB_IRE_SIMULATE_URL=
CMDB_IRE_APPROVE_URL=
CMDB_IRE_EXECUTE_URL=
CMDB_IRE_VERIFY_URL=
