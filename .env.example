# Base URL that already exposes /cis, /timeline, /relationships, and /health.
CMDB_API_BASE_URL=https://your-servicenow-api.example.com

# Choose bearer token OR basic authentication. These remain server-side.
CMDB_API_TOKEN=
CMDB_API_USERNAME=
CMDB_API_PASSWORD=

# Optional. If omitted, remediation proposals use CMDB_API_BASE_URL/remediate.
CMDB_REMEDIATE_URL=
CMDB_IMPORT_URL=
